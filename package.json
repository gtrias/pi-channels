{
  "name": "pi-channels",
  "version": "0.2.0",
  "description": "Two-way channel extension for pi — route messages between agents and Telegram, webhooks, and custom adapters. Includes chat bridge with persistent sessions, streaming drafts, PDF/voice/photo support.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "author": "Espen Nilsen",
  "contributors": [
    "Genar Trias <gtrias@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gtrias/pi-channels.git"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  }
}
